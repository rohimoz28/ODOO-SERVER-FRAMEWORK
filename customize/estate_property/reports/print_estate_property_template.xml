<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_estate_property_details_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Property: <span t-field="doc.name"/></h2>
                        <p><strong>Expected Price:</strong> <span t-field="doc.expected_price"/></p>
                        <p><strong>Selling Price:</strong> <span t-field="doc.selling_price"/></p>
                        <p><strong>Status:</strong> <span t-field="doc.state"/></p>

                        <h3>Accepted Offers</h3>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Partner</th>
                                    <th>Price</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="accepted_offers" t-value="doc.offer_ids.filtered(lambda o: o.status == 'accepted')"/>
                                <t t-foreach="accepted_offers" t-as="offer">
                                    <tr>
                                        <td><span t-field="offer.partner_id.name"/></td>
                                        <td><span t-field="offer.price"/></td>
                                        <td><span t-field="offer.status"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>