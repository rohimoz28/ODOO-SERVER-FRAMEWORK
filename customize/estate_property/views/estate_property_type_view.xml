<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="estate_property_type_form_view" model="ir.ui.view">
            <field name="name">property.type.form</field>
            <field name="model">estate.property.type</field>
            <field name="arch" type="xml">
                <form string="Property Type">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Property Type"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="property_type_act_window" model="ir.actions.act_window">
            <field name="name">property.type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">estate.property.type</field>
            <field name="view_mode">form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    There is no examples click here to add new Property Type.
                </p>
            </field>
        </record>

        <menuitem name="Property Type" id="estate_property_type_menu" parent="estate_property.settings" action="property_type_act_window"/>

    </data>
</odoo>